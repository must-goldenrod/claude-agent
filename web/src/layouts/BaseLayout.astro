---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Agent Marketplace - Performance tracking for Claude Code agents' } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/agents', label: 'Agents' },
  { href: '/leaderboard', label: 'Leaderboard' },
  { href: '/compare', label: 'Compare' },
];
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Agent Marketplace</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen flex flex-col">
    <nav class="bg-surface-900 text-white px-6 py-3">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/" class="text-lg font-bold tracking-tight">Agent Marketplace</a>
        <div class="flex gap-6 text-sm">
          {navItems.map(item => (
            <a
              href={item.href}
              class={`hover:text-primary-100 transition-colors ${currentPath === item.href ? 'text-primary-100 font-medium' : 'text-surface-200'}`}
            >
              {item.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <main class="flex-1 max-w-7xl mx-auto w-full px-6 py-8">
      <slot />
    </main>

    <footer class="bg-surface-100 border-t border-surface-200 px-6 py-4 text-sm text-surface-700 text-center">
      Agent Marketplace &mdash; Built for Claude Code sub-agent ecosystem
    </footer>
  </body>
</html>
