---
interface Props {
  name: string;
  description: string;
  version: string;
  composite: number | null;
  tags: string[];
  model: string;
  totalExecutions: number;
}
const { name, description, version, composite, tags, model, totalExecutions } = Astro.props;
const scoreColor = composite == null ? 'text-surface-700' : composite >= 0.8 ? 'text-green-600' : composite >= 0.6 ? 'text-yellow-600' : 'text-red-600';
---

<a href={`/agents/${name}`} class="block bg-white rounded-xl shadow-sm border border-surface-200 p-5 hover:shadow-md transition-shadow">
  <div class="flex justify-between items-start mb-2">
    <h3 class="font-semibold text-surface-900">{name}</h3>
    <span class="text-xs text-surface-700 bg-surface-100 px-2 py-0.5 rounded">v{version}</span>
  </div>
  <p class="text-sm text-surface-700 mb-3 line-clamp-2">{description || '(no description)'}</p>
  <div class="flex items-center gap-4 text-sm">
    <span class={`font-mono font-bold ${scoreColor}`}>
      {composite != null ? composite.toFixed(2) : 'N/A'}
    </span>
    <span class="text-surface-700">{totalExecutions} runs</span>
    <span class="text-surface-700">{model}</span>
  </div>
  {tags.length > 0 && (
    <div class="flex gap-1.5 mt-3 flex-wrap">
      {tags.map(tag => (
        <span class="text-xs bg-primary-50 text-primary-700 px-2 py-0.5 rounded-full">{tag}</span>
      ))}
    </div>
  )}
</a>
