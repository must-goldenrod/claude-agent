---
interface Props {
  label: string;
  value: string | number;
}
const { label, value } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm border border-surface-200 px-6 py-4 text-center">
  <div class="text-3xl font-bold text-surface-900">{value}</div>
  <div class="text-sm text-surface-700 mt-1">{label}</div>
</div>
