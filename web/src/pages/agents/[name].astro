---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScoreBar from '../../components/ScoreBar.astro';
import fs from 'node:fs';
import path from 'node:path';

export function getStaticPaths() {
  const dataDir = path.join(process.cwd(), 'src/data/stats');
  if (!fs.existsSync(dataDir)) return [];

  const files = fs.readdirSync(dataDir).filter(f => f.endsWith('.json'));
  return files.map(f => ({
    params: { name: f.replace('.json', '') },
  }));
}

const { name } = Astro.params;

let agents = [];
try { agents = (await import('../../data/agents.json')).default; } catch {}

const agent = agents.find(a => a.name === name);

let detail = null;
try {
  const statsPath = path.join(process.cwd(), 'src/data/stats', `${name}.json`);
  if (fs.existsSync(statsPath)) {
    detail = JSON.parse(fs.readFileSync(statsPath, 'utf8'));
  }
} catch {}

const profile = detail?.profile || agent?.performance || null;
const installCmd = `agent-tracker market install ${name}`;
---

<BaseLayout title={name || 'Agent'}>
  <div class="mb-6">
    <a href="/agents" class="text-sm text-primary-600 hover:underline">← Back to agents</a>
  </div>

  <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-bold">{name}</h1>
      {agent && <p class="text-surface-700 mt-1">{agent.description || '(no description)'}</p>}
      <div class="flex gap-3 mt-2 text-sm text-surface-700">
        {agent?.version && <span>v{agent.version}</span>}
        {agent?.model && <span>Model: {agent.model}</span>}
        {agent?.tags?.length > 0 && (
          <span>Tags: {agent.tags.join(', ')}</span>
        )}
      </div>
    </div>
  </div>

  {profile ? (
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <section class="bg-white rounded-xl border border-surface-200 p-6">
        <h2 class="text-lg font-semibold mb-4">Performance Profile</h2>
        <div class="space-y-3">
          <ScoreBar label="Quality" score={profile.quality || 0} />
          <ScoreBar label="Efficiency" score={profile.efficiency || 0} />
          <ScoreBar label="Reliability" score={profile.reliability || 0} />
          <ScoreBar label="Impact" score={profile.impact || 0} />
        </div>
        <div class="mt-4 pt-4 border-t border-surface-200">
          <div class="flex justify-between items-center">
            <span class="text-surface-700">Composite Score</span>
            <span class="text-2xl font-bold">{(profile.composite || 0).toFixed(2)}</span>
          </div>
          {profile.sampleSize != null && (
            <div class="text-sm text-surface-700 mt-1">Based on {profile.sampleSize} executions</div>
          )}
        </div>
      </section>

      <section class="bg-white rounded-xl border border-surface-200 p-6">
        <h2 class="text-lg font-semibold mb-4">Details</h2>

        {profile.qualityDetails && Object.keys(profile.qualityDetails).length > 0 && (
          <div class="mb-4">
            <h3 class="text-sm font-medium text-surface-700 mb-2">Quality Breakdown</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              {Object.entries(profile.qualityDetails).map(([k, v]) => (
                <div class="flex justify-between bg-surface-50 rounded px-3 py-1.5">
                  <span class="text-surface-700 capitalize">{k}</span>
                  <span class="font-mono">{typeof v === 'number' ? v.toFixed(2) : String(v)}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {profile.efficiencyDetails && Object.keys(profile.efficiencyDetails).length > 0 && (
          <div class="mb-4">
            <h3 class="text-sm font-medium text-surface-700 mb-2">Efficiency Breakdown</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              {Object.entries(profile.efficiencyDetails).map(([k, v]) => (
                <div class="flex justify-between bg-surface-50 rounded px-3 py-1.5">
                  <span class="text-surface-700 capitalize">{k.replace(/([A-Z])/g, ' $1').trim()}</span>
                  <span class="font-mono">{typeof v === 'number' ? v.toFixed(2) : String(v)}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {profile.reliabilityDetails && Object.keys(profile.reliabilityDetails).length > 0 && (
          <div>
            <h3 class="text-sm font-medium text-surface-700 mb-2">Reliability Breakdown</h3>
            <div class="grid grid-cols-2 gap-2 text-sm">
              {Object.entries(profile.reliabilityDetails).map(([k, v]) => (
                <div class="flex justify-between bg-surface-50 rounded px-3 py-1.5">
                  <span class="text-surface-700 capitalize">{k.replace(/([A-Z])/g, ' $1').trim()}</span>
                  <span class="font-mono">{typeof v === 'number' ? v.toFixed(2) : String(v)}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        {profile.context && (
          <div class="mt-4 pt-4 border-t border-surface-200">
            <h3 class="text-sm font-medium text-surface-700 mb-2">Context</h3>
            <div class="text-sm space-y-1">
              {profile.context.model && <div>Model: <span class="font-mono">{profile.context.model}</span></div>}
              {profile.context.domain && <div>Domain: <span class="capitalize">{profile.context.domain}</span></div>}
              {profile.context.projectTypes?.length > 0 && <div>Projects: {profile.context.projectTypes.join(', ')}</div>}
            </div>
          </div>
        )}
      </section>
    </div>
  ) : (
    <div class="bg-white rounded-xl border border-surface-200 p-6 text-center text-surface-700">
      <p>No performance data available for this agent.</p>
      <p class="text-sm mt-2">Run the agent through the pipeline and use <code class="bg-surface-100 px-1 rounded">profile refresh</code> to generate data.</p>
    </div>
  )}

  <section class="mt-8 bg-white rounded-xl border border-surface-200 p-6">
    <h2 class="text-lg font-semibold mb-3">Install</h2>
    <div class="flex items-center gap-2 bg-surface-900 text-green-400 rounded-lg px-4 py-3 font-mono text-sm">
      <span class="select-all">{installCmd}</span>
    </div>
  </section>

  {detail?.executions?.length > 0 && (
    <section class="mt-8 bg-white rounded-xl border border-surface-200 p-6">
      <h2 class="text-lg font-semibold mb-4">Recent Executions</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-surface-700 border-b border-surface-200">
              <th class="pb-2 pr-4">#</th>
              <th class="pb-2 pr-4">Date</th>
              <th class="pb-2 pr-4">Duration</th>
              <th class="pb-2 pr-4">Schema</th>
              <th class="pb-2 pr-4">Project</th>
              <th class="pb-2">Model</th>
            </tr>
          </thead>
          <tbody>
            {detail.executions.slice(0, 20).map(ex => (
              <tr class="border-b border-surface-100">
                <td class="py-2 pr-4 font-mono text-surface-700">{ex.id}</td>
                <td class="py-2 pr-4">{ex.timestamp ? new Date(ex.timestamp).toLocaleDateString() : '—'}</td>
                <td class="py-2 pr-4">{ex.duration_ms ? `${(ex.duration_ms / 1000).toFixed(1)}s` : '—'}</td>
                <td class="py-2 pr-4">{ex.schema_score != null ? ex.schema_score.toFixed(2) : '—'}</td>
                <td class="py-2 pr-4">{ex.project_type || '—'}</td>
                <td class="py-2">{ex.model_version || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}

  {detail?.history?.length > 0 && (
    <section class="mt-8 bg-white rounded-xl border border-surface-200 p-6">
      <h2 class="text-lg font-semibold mb-4">Score History</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-surface-700 border-b border-surface-200">
              <th class="pb-2 pr-4">Date</th>
              <th class="pb-2 pr-4">Quality</th>
              <th class="pb-2 pr-4">Efficiency</th>
              <th class="pb-2 pr-4">Reliability</th>
              <th class="pb-2 pr-4">Impact</th>
              <th class="pb-2">Composite</th>
            </tr>
          </thead>
          <tbody>
            {detail.history.map(h => (
              <tr class="border-b border-surface-100">
                <td class="py-2 pr-4">{h.date ? new Date(h.date).toLocaleDateString() : '—'}</td>
                <td class="py-2 pr-4 font-mono">{h.quality?.toFixed(2) ?? '—'}</td>
                <td class="py-2 pr-4 font-mono">{h.efficiency?.toFixed(2) ?? '—'}</td>
                <td class="py-2 pr-4 font-mono">{h.reliability?.toFixed(2) ?? '—'}</td>
                <td class="py-2 pr-4 font-mono">{h.impact?.toFixed(2) ?? '—'}</td>
                <td class="py-2 font-mono font-bold">{h.composite?.toFixed(2) ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  )}
</BaseLayout>
