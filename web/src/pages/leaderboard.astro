---
import BaseLayout from '../layouts/BaseLayout.astro';
import ScoreBar from '../components/ScoreBar.astro';

let leaderboard = [];
let teams = [];
try {
  leaderboard = (await import('../data/leaderboard.json')).default;
  teams = (await import('../data/teams.json')).default;
} catch {}
---

<BaseLayout title="Leaderboard">
  <h1 class="text-2xl font-bold mb-6">Leaderboard</h1>

  {leaderboard.length > 0 ? (
    <section class="bg-white rounded-xl border border-surface-200 p-6 mb-8">
      <h2 class="text-lg font-semibold mb-4">Agent Rankings</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="text-left text-surface-700 border-b border-surface-200">
              <th class="pb-2 pr-4 w-12">#</th>
              <th class="pb-2 pr-4">Agent</th>
              <th class="pb-2 pr-4">Composite</th>
              <th class="pb-2 pr-4">Quality</th>
              <th class="pb-2 pr-4">Efficiency</th>
              <th class="pb-2 pr-4">Reliability</th>
              <th class="pb-2 pr-4">Impact</th>
              <th class="pb-2 pr-4">Samples</th>
              <th class="pb-2">Tags</th>
            </tr>
          </thead>
          <tbody>
            {leaderboard.map(entry => (
              <tr class="border-b border-surface-100 hover:bg-surface-50">
                <td class="py-3 pr-4 font-bold text-surface-700">{entry.rank}</td>
                <td class="py-3 pr-4">
                  <a href={`/agents/${entry.name}`} class="text-primary-600 hover:underline font-medium">{entry.name}</a>
                </td>
                <td class="py-3 pr-4 font-mono font-bold">{entry.composite.toFixed(2)}</td>
                <td class="py-3 pr-4 font-mono">{entry.quality.toFixed(2)}</td>
                <td class="py-3 pr-4 font-mono">{entry.efficiency.toFixed(2)}</td>
                <td class="py-3 pr-4 font-mono">{entry.reliability.toFixed(2)}</td>
                <td class="py-3 pr-4 font-mono">{entry.impact.toFixed(2)}</td>
                <td class="py-3 pr-4 text-surface-700">{entry.sample_size}</td>
                <td class="py-3">
                  <div class="flex gap-1 flex-wrap">
                    {entry.tags.map(t => (
                      <span class="text-xs bg-primary-50 text-primary-700 px-2 py-0.5 rounded-full">{t}</span>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  ) : (
    <div class="bg-white rounded-xl border border-surface-200 p-6 text-center text-surface-700 mb-8">
      <p>No leaderboard data yet. Publish agents with performance data to populate rankings.</p>
    </div>
  )}

  {teams.length > 0 && (
    <section class="bg-white rounded-xl border border-surface-200 p-6">
      <h2 class="text-lg font-semibold mb-4">Team Rankings</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {teams.map((t, i) => (
          <div class="border border-surface-200 rounded-lg p-4">
            <div class="flex items-center gap-3 mb-2">
              <span class="text-lg font-bold text-surface-700">#{i + 1}</span>
              <span class="font-semibold text-surface-900 capitalize">{t.name}</span>
            </div>
            <ScoreBar label="Avg Score" score={t.avg_score} />
            <div class="text-xs text-surface-700 mt-2">{t.agent_count} agents · {t.total_executions} executions</div>
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
