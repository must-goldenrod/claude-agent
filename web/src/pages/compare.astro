---
import BaseLayout from '../layouts/BaseLayout.astro';
import CompareTable from '../components/CompareTable.tsx';

let agents = [];
try {
  agents = (await import('../data/agents.json')).default;
} catch {}
---

<BaseLayout title="Compare">
  <h1 class="text-2xl font-bold mb-6">Compare Agents</h1>
  <CompareTable client:load agents={agents} />
</BaseLayout>
