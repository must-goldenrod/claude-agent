---
import BaseLayout from '../layouts/BaseLayout.astro';
import StatCard from '../components/StatCard.astro';
import AgentCard from '../components/AgentCard.astro';

let summary = { total_agents: 0, total_executions: 0, avg_score: 0, team_count: 0 };
let agents = [];
let teams = [];

try {
  summary = (await import('../data/summary.json')).default;
  agents = (await import('../data/agents.json')).default;
  teams = (await import('../data/teams.json')).default;
} catch {}

const topAgents = agents.slice(0, 6);
const topTeams = teams.slice(0, 6);
---

<BaseLayout title="Dashboard">
  <h1 class="text-2xl font-bold mb-6">Dashboard</h1>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
    <StatCard label="Agents" value={summary.total_agents} />
    <StatCard label="Total Executions" value={summary.total_executions.toLocaleString()} />
    <StatCard label="Avg Score" value={summary.avg_score ? summary.avg_score.toFixed(2) : '—'} />
    <StatCard label="Teams" value={summary.team_count} />
  </div>

  <section class="mb-10">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-xl font-semibold">Top Agents</h2>
      <a href="/agents" class="text-sm text-primary-600 hover:underline">View all →</a>
    </div>
    {topAgents.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {topAgents.map(a => (
          <AgentCard
            name={a.name}
            description={a.description}
            version={a.version}
            composite={a.composite}
            tags={a.tags}
            model={a.model}
            totalExecutions={a.total_executions}
          />
        ))}
      </div>
    ) : (
      <p class="text-surface-700">No agent data yet. Run <code class="bg-surface-100 px-1.5 py-0.5 rounded text-sm">agent-tracker export-data</code> to generate data.</p>
    )}
  </section>

  <section>
    <h2 class="text-xl font-semibold mb-4">Teams</h2>
    {topTeams.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        {topTeams.map(t => (
          <div class="bg-white rounded-lg border border-surface-200 p-4 text-center">
            <div class="font-semibold text-surface-900 capitalize">{t.name}</div>
            <div class="text-2xl font-bold text-primary-600 mt-1">{t.avg_score.toFixed(2)}</div>
            <div class="text-xs text-surface-700 mt-1">{t.agent_count} agents · {t.total_executions} runs</div>
          </div>
        ))}
      </div>
    ) : (
      <p class="text-surface-700">No team data available.</p>
    )}
  </section>
</BaseLayout>
